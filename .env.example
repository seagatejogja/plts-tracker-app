# Database Connection (Supabase / Vercel Postgres / Neon)
# Transaction connection string (usually port 6543 or 5432)
DATABASE_URL="postgres://user:password@host:port/dbname?pgbouncer=true"

# Direct connection string for migrations (usually port 5432)
DIRECT_URL="postgres://user:password@host:port/dbname"

# App Base URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
